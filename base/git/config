[core]
  pager = less -FRSX
  editor = nvim

[init]
  defaultBranch = main

[github]
  user = sindrenm

[pull]
  rebase = false

[push]
  default = simple

[clean]
  requireForce = false

[include]
  path = aliases
  path = colors
  path = lfs
  path = user
  path = private

[merge]
  conflictstyle = diff3

[url "git@github.com:"]
  insteadOf = github:

[url "git@github.com:sindrenm/"]
  insteadOf = sindrenm:

[url "git@github.schibsted.io:finn/"]
  insteadOf = finn:

[url "git@heroku.com:"]
  insteadOf = heroku:
